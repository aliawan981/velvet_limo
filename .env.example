# Environment Variables Template
# Copy this to a file named .env in the project root
# Add .env to .gitignore to avoid committing sensitive data

# Microsoft Graph API Configuration
MICROSOFT_GRAPH_TENANT_ID=your-tenant-id
MICROSOFT_GRAPH_CLIENT_ID=your-client-id
# Use the client secret VALUE from Azure App Registration, not the secret ID
MICROSOFT_GRAPH_CLIENT_SECRET=your-client-secret-value
MICROSOFT_GRAPH_SENDER=your-mailbox@yourdomain.com

# Optional: Default sender and admin email
DEFAULT_FROM_EMAIL=your-mailbox@yourdomain.com
ADMIN_EMAIL=admin@velvetlimousine.com

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
USE_GOOGLE_MAPS_API=False

